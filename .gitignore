# Downloaded sources and generated workloads
/data/sources/
/data/workloads/*
!/data/workloads/validation.bin
!/data/workloads/validation.bin.manifest.json

# Generated manifests and orchestration locks; retain directory markers
/data/manifests/*
!/data/manifests/.gitkeep
/data/.*.lock

# Benchmark outputs and generated figures; retain the empty directory marker
/results/*
!/results/.gitkeep
/plots/
/figures/
*.log

# Incomplete downloads, atomic-write staging files, and editor backups
*.partial
*.partial-*
*.tmp
*.temp
*.bak
*.orig
*.rej
*~
*.swp
*.swo

# Local environment files and credentials
.env
.env.*
!.env.example
*.pem
*.key

# Editors, operating systems, and Codex-local metadata
.DS_Store
Thumbs.db
.idea/
.vscode/
.codex/
.agents/
