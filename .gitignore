# Native, CMake, Ninja, coverage, and profiling products
/build/
/cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json
Testing/
build.ninja
.ninja_deps
.ninja_log
*.d
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
*.gcda
*.gcno
*.profraw
*.profdata
/core
/core.*

# Python caches, packaging products, and virtual environments
__pycache__/
*.py[cod]
*$py.class
.eggs/
*.egg
*.egg-info/
/dist/
pip-wheel-metadata/
.pytest_cache/
.hypothesis/
.mypy_cache/
.ruff_cache/
.pyre/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.venv/
venv/
env/
